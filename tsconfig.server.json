{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "rootDir": ".",
      "outDir": "./dist",
      "strict": false,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "typeRoots": ["./node_modules/@types", "./server/types"]
    },
    "include": ["server/**/*", "shared/**/*", "server/types"],
    "exclude": ["node_modules", "client", "dist"]
  }